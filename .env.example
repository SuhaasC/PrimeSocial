# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# SMTP - Required for the application form. Get these from your email provider
# (e.g. Gmail App Password, SendGrid, Resend, Mailgun, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Optional: "From" address shown in emails (defaults to SMTP_USER)
CONTACT_FROM_EMAIL=noreply@primesocial.agency
